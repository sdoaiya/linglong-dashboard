{
  "name": "linglong-dashboard",
  "version": "1.0.0",
  "description": "灵笼集团 OpenClaw 看板系统 - 为19人团队定制的组织架构可视化工具",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "deploy": "npm run build && gh-pages -d dist"
  },
  "dependencies": {
    "lit": "^3.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^6.0.2",
    "vite": "^5.0.0"
  },
  "keywords": [
    "dashboard",
    "lit",
    "typescript",
    "vite",
    "linglong",
    "web-components",
    "kanban",
    "organization-chart",
    "team-management",
    "openclaw"
  ],
  "author": "灵笼集团开发部 <dev@linglong.group>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/linglong-group/linglong-dashboard.git"
  },
  "bugs": {
    "url": "https://github.com/linglong-group/linglong-dashboard/issues"
  },
  "homepage": "https://linglong-group.github.io/linglong-dashboard",
  "engines": {
    "node": ">=18.0.0"
  }
}
